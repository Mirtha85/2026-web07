@model DishListViewModel

<div class="container my-5">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h2 class="display-3 fw-bold" style="color: var(--secondary)">Nuestra <span style="color: var(--primary)">Carta</span></h2>
            <p class="text-muted">Brasa & Tradición - Sabores que cuentan historias</p>
            <div class="divider mx-auto" style="width: 100px; height: 4px; background: var(--primary); border-radius: 2px;"></div>
        </div>
    </div>

    @{
        var groupedDishes = Model.Dishes.GroupBy(d => d.Category.CategoryName);
    }

    @foreach (var group in groupedDishes)
    {
        <div class="category-section mb-5">
            <h3 class="category-title mb-4 pb-2 border-bottom fw-bold" style="color: var(--secondary)">
                @group.Key
            </h3>
            
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var dish in group)
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm dish-item-horizontal overflow-hidden p-3" style="border-radius: 15px; background: white;">
                            <div class="row g-0 align-items-center">
                                <div class="col-4">
                                    <img src="@dish.ImageThumbnailUrl" class="img-fluid rounded-3" alt="@dish.Name" style="height: 120px; width: 100%; object-fit: cover;">
                                </div>
                                <div class="col-8">
                                    <div class="card-body py-0 ps-3">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h5 class="fw-bold mb-1" style="font-size: 1.1rem;">@dish.Name</h5>
                                            <span class="fw-bold text-primary">Bs @dish.Price.ToString("F2")</span>
                                        </div>
                                        <p class="text-muted small mb-0" style="line-height: 1.3;">@dish.LongDescription</p>
                                        @if(dish.IsDishOfTheWeek)
                                        {
                                            <span class="badge bg-light text-danger border border-danger mt-2" style="font-size: 0.7rem;">⭐ Recomendación del Chef</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .dish-item-horizontal {
        transition: all 0.3s ease;
    }
    .dish-item-horizontal:hover {
        transform: scale(1.02);
        box-shadow: 0 10px 25px rgba(0,0,0,0.05) !important;
    }
    .category-title {
        position: relative;
        display: inline-block;
    }
    .category-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 50px;
        height: 3px;
        background: var(--primary);
    }
</style>
